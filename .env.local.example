# ============================================
# L'Atelier IA — Configuration locale
# ============================================
# Copier ce fichier vers .env :
#   cp .env.local.example .env
#
# Puis remplacer les valeurs par vos vraies clés API.
# L'application fonctionne en mode dégradé sans clés.
# ============================================

# Claude API — enrichissement IA des fiches techniques
# Obtenir sur : https://console.anthropic.com/settings/keys
# Format : sk-ant-api03-xxxxxxxxxxxx
VITE_CLAUDE_API_KEY=

# Replicate — génération d'images via Flux Pro
# Obtenir sur : https://replicate.com/account/api-tokens
# Format : r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_REPLICATE_API_KEY=

# OpenAI — génération d'images via DALL-E 3
# Obtenir sur : https://platform.openai.com/api-keys
# Format : sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_OPENAI_API_KEY=
